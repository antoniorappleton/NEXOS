rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to get user profile document data
    function getUserData() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }

    // Helper to check if user has teacher or admin role
    function isTeacherOrAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'teacher' || getUserData().role == 'admin');
    }

    // Profiles rules
    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isTeacherOrAdmin());
      allow delete: if isTeacherOrAdmin();
    }

    // Classes, Modules, Lessons, Contents, Assignments
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow write: if isTeacherOrAdmin();
    }

    match /modules/{moduleId} {
      allow read: if isAuthenticated();
      allow write: if isTeacherOrAdmin();
    }

    match /lessons/{lessonId} {
      allow read: if isAuthenticated();
      allow write: if isTeacherOrAdmin();
    }

    match /contents/{contentId} {
      allow read: if isAuthenticated();
      allow write: if isTeacherOrAdmin();
    }

    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow write: if isTeacherOrAdmin();
    }

    // Submissions
    match /submissions/{submissionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.studentId == request.auth.uid || isTeacherOrAdmin());
      allow delete: if isTeacherOrAdmin();
    }

    // Grades
    match /grades/{gradeId} {
      allow read: if isAuthenticated() && (resource.data.studentId == request.auth.uid || isTeacherOrAdmin());
      allow write: if isTeacherOrAdmin();
    }

    // Attendance Sessions
    match /attendance_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isTeacherOrAdmin();
    }

    // GitHub Repo Activities
    match /github_repo_activities/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.studentId == request.auth.uid || isTeacherOrAdmin());
    }
  }
}
